package backend.dao;

import java.sql.*;

public class PatientDAO {
    public static String registerPatient(String name, String phone, int age, String bloodGroup, String gender, String password) {
        String generatedId = null;
        try (Connection conn = DBConnection.getConnection()) {
            if (conn == null) return null;

            // Get next sequence value for the ID
            String seqQuery = "SELECT patient_seq.NEXTVAL FROM dual";
            try (PreparedStatement seqStmt = conn.prepareStatement(seqQuery);
                 ResultSet rs = seqStmt.executeQuery()) {
                if (rs.next()) {
                    int seqValue = rs.getInt(1);
                    generatedId = "P" + seqValue;
                }
            }

            if (generatedId != null) {
                String insertQuery = "INSERT INTO patients (patient_id, name, phone, age, blood_group, gender, password) VALUES (?, ?, ?, ?, ?, ?, ?)";
                try (PreparedStatement pt = conn.prepareStatement(insertQuery)) {
                    pt.setString(1, generatedId);
                    pt.setString(2, name);
                    pt.setString(3, phone);
                    pt.setInt(4, age);
                    pt.setString(5, bloodGroup);
                    pt.setString(6, gender);
                    pt.setString(7, password);
                    int rows = pt.executeUpdate();
                    if (rows > 0) {
                        return generatedId;
                    }
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
            return "ERROR: " + e.getMessage();
        }
        return null;
    }

    public static boolean authenticatePatient(String patientId, String password) {
        try (Connection conn = DBConnection.getConnection()) {
            if (conn == null) return false;

            String query = "SELECT password FROM patients WHERE patient_id = ?";
            try (PreparedStatement pt = conn.prepareStatement(query)) {
                pt.setString(1, patientId);
                try (ResultSet rs = pt.executeQuery()) {
                    if (rs.next()) {
                        String dbPassword = rs.getString("password");
                        if (dbPassword != null && dbPassword.equals(password)) {
                            return true;
                        }
                    }
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
        return false;
    }

    public static String[] getPatientProfile(String patientId) {
        try (Connection conn = DBConnection.getConnection()) {
            if (conn == null) return null;
            String query = "SELECT name, phone, age, blood_group, gender FROM patients WHERE patient_id = ?";
            try (PreparedStatement pt = conn.prepareStatement(query)) {
                pt.setString(1, patientId);
                try (ResultSet rs = pt.executeQuery()) {
                    if (rs.next()) {
                        return new String[]{
                            rs.getString("name"),
                            rs.getString("phone"),
                            rs.getString("age"),
                            rs.getString("blood_group"),
                            rs.getString("gender")
                        };
                    }
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
        return null;
    }

    private static String[][] getTableData(String query, String patientId, int columnCount) {
        java.util.List<String[]> dataList = new java.util.ArrayList<>();
        try (Connection conn = DBConnection.getConnection()) {
            if (conn == null) return new String[0][0];
            try (PreparedStatement pt = conn.prepareStatement(query)) {
                pt.setString(1, patientId);
                try (ResultSet rs = pt.executeQuery()) {
                    while (rs.next()) {
                        String[] row = new String[columnCount];
                        for (int i = 0; i < columnCount; i++) {
                            row[i] = rs.getString(i + 1);
                        }
                        dataList.add(row);
                    }
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
        return dataList.toArray(new String[0][]);
    }

    public static String[][] getHealthRecords(String patientId) {
        String query = "SELECT doctor_id, diagnosis, TO_CHAR(date_recorded, 'YYYY-MM-DD') FROM health_records WHERE patient_id = ? ORDER BY date_recorded DESC";
        return getTableData(query, patientId, 3);
    }

    public static String[][] getServiceRecords(String patientId) {
        String query = "SELECT service_name, TO_CHAR(service_date, 'YYYY-MM-DD'), amount, status FROM service_records WHERE patient_id = ? ORDER BY service_date DESC";
        return getTableData(query, patientId, 4);
    }

    public static String[][] getReports(String patientId) {
        String query = "SELECT file_name, file_path FROM reports WHERE patient_id = ?";
        return getTableData(query, patientId, 2);
    }

    public static String[][] getAppointmentHistory(String patientId) {
        // App history may exist in appointment_history, which has record_id, doc_id, app_date, diag, pres, status
        String query = "SELECT doctor_id, TO_CHAR(app_date, 'YYYY-MM-DD HH24:MI'), diagnosis, prescription, status FROM appointment_history WHERE patient_id = ? ORDER BY app_date DESC";
        return getTableData(query, patientId, 5);
    }
}
