package frontend.patient;

import backend.dao.PatientDAO;
import frontend.common.UITheme;

import javax.swing.*;
import java.awt.*;
import java.awt.event.ActionEvent;

public class PatientRegistrationUI extends JFrame {

    public PatientRegistrationUI() {
        setTitle("Patient Registration");
        setSize(500, 900);
        setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
        setLocationRelativeTo(null);

        JPanel bgPanel = UITheme.createGradientPanel();
        bgPanel.setLayout(new GridBagLayout());

        JPanel mainContent = new JPanel();
        mainContent.setLayout(new BoxLayout(mainContent, BoxLayout.Y_AXIS));
        mainContent.setOpaque(false);

        // TOP TITLE
        JLabel lblTitle = new JLabel("PATIENT REGISTRATION", SwingConstants.CENTER);
        lblTitle.setFont(UITheme.TITLE_FONT);
        lblTitle.setForeground(UITheme.TEXT_LIGHT);
        lblTitle.setAlignmentX(Component.CENTER_ALIGNMENT);
        mainContent.add(lblTitle);
        mainContent.add(Box.createRigidArea(new Dimension(0, 20)));

        // DARK CENTRAL PANEL
        JPanel regPanel = new JPanel();
        regPanel.setLayout(new BoxLayout(regPanel, BoxLayout.Y_AXIS));
        regPanel.setBackground(UITheme.DARK_PANEL);
        regPanel.setBorder(BorderFactory.createEmptyBorder(30, 40, 30, 40));
        regPanel.setAlignmentX(Component.CENTER_ALIGNMENT);
        
        // Full Name
        JLabel lblName = new JLabel("Full Name");
        lblName.setForeground(UITheme.TEXT_LIGHT);
        regPanel.add(lblName);
        regPanel.add(Box.createRigidArea(new Dimension(0, 5)));
        JTextField txtName = new JTextField();
        JPanel pnlName = UITheme.createStyledTextField(txtName);
        pnlName.setMaximumSize(new Dimension(300, 45));
        regPanel.add(pnlName);
        regPanel.add(Box.createRigidArea(new Dimension(0, 20)));

        // Phone Number
        JLabel lblPhone = new JLabel("Phone Number");
        lblPhone.setForeground(UITheme.TEXT_LIGHT);
        regPanel.add(lblPhone);
        regPanel.add(Box.createRigidArea(new Dimension(0, 5)));
        JTextField txtPhone = new JTextField();
        JPanel pnlPhone = UITheme.createStyledTextField(txtPhone);
        pnlPhone.setMaximumSize(new Dimension(300, 45));
        regPanel.add(pnlPhone);
        regPanel.add(Box.createRigidArea(new Dimension(0, 20)));

        // Age
        JLabel lblAge = new JLabel("Age");
        lblAge.setForeground(UITheme.TEXT_LIGHT);
        regPanel.add(lblAge);
        regPanel.add(Box.createRigidArea(new Dimension(0, 5)));
        JTextField txtAge = new JTextField();
        JPanel pnlAge = UITheme.createStyledTextField(txtAge);
        pnlAge.setMaximumSize(new Dimension(300, 45));
        regPanel.add(pnlAge);
        regPanel.add(Box.createRigidArea(new Dimension(0, 20)));

        // Blood Group
        JLabel lblBlood = new JLabel("Blood Group");
        lblBlood.setForeground(UITheme.TEXT_LIGHT);
        regPanel.add(lblBlood);
        regPanel.add(Box.createRigidArea(new Dimension(0, 5)));
        String[] bloodGroups = {"A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"};
        JComboBox<String> comboBlood = new JComboBox<>(bloodGroups);
        comboBlood.setMaximumSize(new Dimension(300, 45));
        comboBlood.setFont(UITheme.MAIN_FONT);
        regPanel.add(comboBlood);
        regPanel.add(Box.createRigidArea(new Dimension(0, 20)));

        // Password
        JLabel lblPass = new JLabel("Password");
        lblPass.setForeground(UITheme.TEXT_LIGHT);
        regPanel.add(lblPass);
        regPanel.add(Box.createRigidArea(new Dimension(0, 5)));
        JPasswordField txtPass = new JPasswordField();
        JPanel pnlPass = UITheme.createStyledTextField(txtPass);
        pnlPass.setMaximumSize(new Dimension(300, 45));
        regPanel.add(pnlPass);
        regPanel.add(Box.createRigidArea(new Dimension(0, 20)));

        // Confirm Password
        JLabel lblConfirm = new JLabel("Confirm Password");
        lblConfirm.setForeground(UITheme.TEXT_LIGHT);
        regPanel.add(lblConfirm);
        regPanel.add(Box.createRigidArea(new Dimension(0, 5)));
        JPasswordField txtConfirm = new JPasswordField();
        JPanel pnlConfirm = UITheme.createStyledTextField(txtConfirm);
        pnlConfirm.setMaximumSize(new Dimension(300, 45));
        regPanel.add(pnlConfirm);
        regPanel.add(Box.createRigidArea(new Dimension(0, 20)));

        // Gender
        JLabel lblGender = new JLabel("Gender");
        lblGender.setForeground(UITheme.TEXT_LIGHT);
        regPanel.add(lblGender);
        regPanel.add(Box.createRigidArea(new Dimension(0, 5)));
        
        JPanel genderPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 10, 0));
        genderPanel.setOpaque(false);
        genderPanel.setMaximumSize(new Dimension(300, 40));
        
        JRadioButton rbMale = new JRadioButton("Male", true);
        JRadioButton rbFemale = new JRadioButton("Female");
        rbMale.setForeground(UITheme.TEXT_LIGHT);
        rbFemale.setForeground(UITheme.TEXT_LIGHT);
        rbMale.setOpaque(false);
        rbFemale.setOpaque(false);
        
        ButtonGroup bg = new ButtonGroup();
        bg.add(rbMale);
        bg.add(rbFemale);
        
        genderPanel.add(rbMale);
        genderPanel.add(rbFemale);
        regPanel.add(genderPanel);
        regPanel.add(Box.createRigidArea(new Dimension(0, 30)));

        // Buttons
        JButton btnRegister = UITheme.createPrimaryButton("REGISTER");
        btnRegister.setMaximumSize(new Dimension(300, 45));
        btnRegister.setAlignmentX(Component.CENTER_ALIGNMENT);
        regPanel.add(btnRegister);
        
        regPanel.add(Box.createRigidArea(new Dimension(0, 10)));
        
        JButton btnCancel = UITheme.createSecondaryButton("CANCEL");
        btnCancel.setMaximumSize(new Dimension(300, 45));
        btnCancel.setAlignmentX(Component.CENTER_ALIGNMENT);
        regPanel.add(btnCancel);

        mainContent.add(regPanel);
        bgPanel.add(mainContent);
        add(bgPanel);

        // Actions
        btnCancel.addActionListener(e -> dispose());
        btnRegister.addActionListener((ActionEvent e) -> {
            String name = txtName.getText();
            String phone = txtPhone.getText();
            String ageStr = txtAge.getText();
            String blood = (String) comboBlood.getSelectedItem();
            String gender = rbMale.isSelected() ? "Male" : "Female";
            
            if(name.isEmpty() || phone.isEmpty() || ageStr.isEmpty()) {
                JOptionPane.showMessageDialog(this, "Name, Phone, and Age cannot be empty");
                return;
            }
            int age = 0;
            try {
                age = Integer.parseInt(ageStr);
            } catch(NumberFormatException ex) {
                JOptionPane.showMessageDialog(this, "Please enter a valid number for age");
                return;
            }
            
            String password = new String(txtPass.getPassword());
            String confirm = new String(txtConfirm.getPassword());
            
            if (password.isEmpty() || !password.equals(confirm)) {
                JOptionPane.showMessageDialog(this, "Passwords do not match or are empty");
                return;
            }

            String patientId = PatientDAO.registerPatient(name, phone, age, blood, gender, password);
            if (patientId != null && patientId.startsWith("ERROR:")) {
                JOptionPane.showMessageDialog(this, "Database Error Details:\n" + patientId.replace("ERROR: ", ""), "Error", JOptionPane.ERROR_MESSAGE);
            } else if (patientId != null) {
                JOptionPane.showMessageDialog(this, "Registration Successful!\nYour unique Patient ID is: " + patientId);
                dispose();
            } else {
                JOptionPane.showMessageDialog(this, "Unknown database error occurred.");
            }
        });
    }
}
